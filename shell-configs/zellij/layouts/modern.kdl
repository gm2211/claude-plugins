layout {
    default_tab_template {
        pane split_direction="vertical" {
            pane size=20 borderless=true {
                plugin location="file:~/.config/zellij/plugins/zellij-vertical-tabs.wasm" {
                    format       "#[fg=#6c7086] {index} {name}"
                    format_active "#[fg=#cdd6f4,bg=#313244,bold,fill] {index} {name}"
                    max_name_length "16"
                    border       "#[fg=#45475a]|"
                    start_index  "1"
                    padding_top  "0"
                }
            }
            pane {
                children
            }
        }
        pane size=1 borderless=true {
            plugin location="https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm" {
                format_left  "{mode}#[fg=#7f849c,bg=#1e1e2e,bold] {session}"
                format_center ""
                format_right "{datetime}"
                format_space "#[bg=#1e1e2e]"
                format_hide_on_overlength "true"
                format_precedence "clr"

                border_enabled  "false"
                hide_frame_for_single_pane "false"
                background "#1e1e2e"
                color_bg "#1e1e2e"

                mode_normal  "#[bg=#89b4fa,fg=#1e1e2e,bold] NORMAL #[bg=#1e1e2e] "
                mode_tmux    "#[bg=#fab387,fg=#1e1e2e,bold] TMUX #[bg=#1e1e2e] "
                mode_pane    "#[bg=#a6e3a1,fg=#1e1e2e,bold] PANE #[bg=#1e1e2e] "
                mode_tab     "#[bg=#cba6f7,fg=#1e1e2e,bold] TAB #[bg=#1e1e2e] "
                mode_resize  "#[bg=#f9e2af,fg=#1e1e2e,bold] RESIZE #[bg=#1e1e2e] "
                mode_move    "#[bg=#94e2d5,fg=#1e1e2e,bold] MOVE #[bg=#1e1e2e] "
                mode_scroll  "#[bg=#f38ba8,fg=#1e1e2e,bold] SCROLL #[bg=#1e1e2e] "
                mode_search  "#[bg=#f5c2e7,fg=#1e1e2e,bold] SEARCH #[bg=#1e1e2e] "
                mode_session "#[bg=#74c7ec,fg=#1e1e2e,bold] SESSION #[bg=#1e1e2e] "
                mode_locked  "#[bg=#6c7086,fg=#1e1e2e,bold] LOCKED #[bg=#1e1e2e] "

                tab_normal              ""
                tab_active              ""
                tab_separator           ""

                pipe_status_format "#[fg=#6c7086,bg=#1e1e2e]{output}"
                pipe_status_rendermode "dynamic"

                datetime         "#[fg=#7f849c,bg=#1e1e2e]{format}"
                datetime_format  "%A, %d %b %Y %H:%M"
                datetime_timezone "America/New_York"
            }
        }
    }
}
