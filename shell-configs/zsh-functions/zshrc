export RENDER_API_KEY_HUDSON=$(security find-generic-password -a render -s render-api-key-hudson -w 2>/dev/null)

# ---------------------------------------------------------------------------
#  Completions
# ---------------------------------------------------------------------------
fpath=(~/.zsh/completions $fpath)
